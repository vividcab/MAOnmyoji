{
    "STATUS-处于模拟器桌面": {
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    {"recognition": "OCR", "roi": [755, 169, 93, 42], "expected": "游戏中心"},
                    {
                        "recognition": "TemplateMatch",
                        "roi": [213, 616, 874, 86],
                        "template": "平台区服/MUMU模拟器桌面dock栏设置按钮.png"
                    }
                ]
            }
        },
        "focus": {
            "succeeded": "[color:red]检测到当前处于模拟器桌面，可能是【游戏闪退了】或者【因游戏包名不正确未能启动游戏】[/color]"
        },
        "_doc": "检测到了桌面上的游戏中心或者状态栏"
    },
    "STATUS-检测游戏已经启动到登录界面了": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [6, 516, 270, 137],
                "template": ["平台区服/适龄提示.png"],
                "threshold": 0.9
            }
        },
        "post_delay": 2000
    },
    "TASK-启动游戏到登录界面": {
        "action": {
            "type": "StartApp",
            "param": {"package": "com.netease.onmyoji.wyzymnqsd_cps"}
        },
        "post_delay": 5000,
        "timeout": 100000,
        "rate_limit": 3000,
        "next": ["STATUS-检测游戏已经启动到登录界面了", "STATUS-处于模拟器桌面"]
    },
    "TASK-关闭游戏": {
        "action": {
            "type": "StopApp",
            "param": {"package": "com.netease.onmyoji.wyzymnqsd_cps"}
        },
        "post_delay": 4000
    },
    "TASK-重新启动游戏": {
        "action": {
            "type": "StopApp",
            "param": {"package": "com.netease.onmyoji.wyzymnqsd_cps"}
        },
        "post_delay": 4000,
        "next": ["TASK-启动游戏到登录界面"]
    }
}
