{
    "ENTRY-逢魔任务": {
        "recognition": {"type": "DirectHit"},
        "next": ["TASK-F-0从庭院进入町中", "[JumpBack]INT-尝试从任意界面回到庭院"],
        "_doc": "执行此任务的时候，游戏应当已经在庭院了；要考虑其他情况，做异常处理"
    },

    "TASK-F-0从庭院进入町中": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [484, 194, 531, 276],
                "template": ["庭院/枫叶庭院町中牌子.png", "庭院/初始庭院町中牌子.png"],
                "threshold": [0.9, 0.9]
            }
        },
        "action": {"type": "Click"},
        "post_delay": 2000,
        "next": ["F-1从町中进入逢魔地图"]
    },
    "F-1从町中进入逢魔地图": {
        "recognition": {"type": "TemplateMatch", "param": {"roi": [616, 136, 54, 73], "template": "逢魔/逢魔灯笼.png"}},
        "action": {"type": "Click"},
        "post_delay": 3000,
        "timeout": 4000,
        "rate_limit": 3000,
        "next": [
            "F-2从逢魔地图到点完4次现世逢魔",
            "F-5-0开始打逢魔BOSS任务",
            "[JumpBack]ACT-检测逢魔灯笼并点击-最多3次"
        ]
    },
    "ACT-检测逢魔灯笼并点击-最多3次": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "Count",
                "custom_recognition_param": {
                    "target": 3,
                    "recognition": {
                        "type": "TemplateMatch",
                        "param": {"template": "逢魔/逢魔灯笼.png", "roi": [616, 136, 54, 73]}
                    }
                }
            }
        },
        "action": {"type": "Click"},
        "post_delay": 1000
    },
    "F-2从逢魔地图到点完4次现世逢魔": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "Count",
