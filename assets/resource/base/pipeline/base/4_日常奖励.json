{
    "ENTRY-领取庭院中的日常奖励": {
        "next": ["TASK-领取日常奖励", "[JumpBack]INT-尝试从任意界面回到庭院"],
        "_doc": "执行此任务的时候，游戏应当已经在庭院了；要考虑其他情况，做异常处理"
    },
    "TASK-领取日常奖励": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [680, 220, 240, 100],
                "template": ["庭院/枫叶庭院町中牌子.png", "庭院/初始庭院町中牌子.png"],
                "threshold": [0.9, 0.9]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "RunTaskList",
                "custom_action_param": {
                    "tasks": [
                        {"taskname": "1-每日签到", "wait": 0.3},
                        {"taskname": "2-领取御魂加成", "wait": 0.3},
                        {"taskname": "3-领取寮包", "wait": 0.3},
                        {"taskname": "4-领取体力", "wait": 0.3},
                        {"taskname": "5-领取勾玉", "wait": 0.3},
                        {"taskname": "6-领邮件", "wait": 0.3},
                        {"taskname": "7-查看悬赏", "wait": 0.3},
                        {"taskname": "8-领取商店每日黑蛋", "wait": 0.3},
                        {"taskname": "9-每日免费抽卡", "wait": 0.3},
                        {"taskname": "10-查看神秘商店并截图记录", "wait": 0.3}
                    ]
                }
            }
        },
        "_doc": "在 RunTaskList 实现中再判断是否真的执行某任务。例如签到任务只需要每天执行一次，领取体力是限时的"
    },

    "1-每日签到": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {"roi": [290, 508, 36, 42], "roi_offset": [-60, -20, 80, 40], "template": "签到/签到.png"}
        },
        "action": {"type": "Click"},
        "post_delay": 1000,
        "timeout": 2000,
        "next": ["1-1检测已经打开了抽签", "[JumpBack]1-ACT-检测点击签到小纸人"],
        "on_error": []
    },
    "1-ACT-检测点击签到小纸人": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {"roi": [290, 508, 36, 42], "roi_offset": [-60, -20, 80, 40], "template": "签到/签到.png"}
